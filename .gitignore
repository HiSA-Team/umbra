
# These are backup files generated by rustfmt
**/*.rs.bk

# OS / editor / Python detritus
.DS_Store
**/.DS_Store
__pycache__/
**/__pycache__/
*.pyc

# Ignore build artifacts
lib/*

# Explicitly track FreeRTOS-Kernel submodule despite lib/* rule
!host/freertos_arm/lib/FreeRTOS-Kernel

# Ignore deprecated
deprecated

# Ignore tmp files and topo
tmp
todo

# Ignore builds for bare_metal_arm
host/bare_metal_arm/bin/*
host/bare_metal_arm/obj/*
host/freertos_arm/bin/*
host/freertos_arm/obj/*

# N657 host build artifacts
host/bare_metal_n657/bin/*
host/bare_metal_n657/obj/*
host/freertos_n657/bin/*
host/freertos_n657/obj/*
host/object_detection_n657/bin/*
host/object_detection_n657/obj/*

# ST upstream clone — vendored subset is committed under
# host/object_detection_n657/{Application,Middlewares,STM32Cube_FW_N6,Model}
host/STM32N6-GettingStarted-ObjectDetection/

# T3 smoke-test transient output (golden_uart.log is tracked)
tools/last_uart.log
tools/last_uart_fault.log

# Local-only: docs (specs, plans, reports) and Claude Code scratch state
docs/
.claude/

# OTFDEC key/nonce material (local-only, never committed)
tools/otfdec_key.bin
tools/otfdec_nonce.bin

# Master key — generated locally by `python3 tools/gen_key.py`. The matching
# Rust constants (src/.../boot/src/master_key.rs) stay tracked so a fresh
# clone can `cargo check` before key generation; the binary form is local-only.
tools/master_key.bin
