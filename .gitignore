debug_session
documentation/*

# Ignore crates builds
src/*/target/*
src/*/*/target/*
src/*/*/*/target/*
src/*/*/*/*/target/*

# Ignore deprecated
deprecated

# Ignore tmp files and topo
tmp
todo

